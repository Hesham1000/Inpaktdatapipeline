# Kayan SDG Data Pipeline — Environment Variables
# Copy this file to .env and fill in your values

# LlamaCloud API key (get from https://cloud.llamaindex.ai)
LLAMA_CLOUD_API_KEY=llx-xxxxx

# Optional: OpenAI key for QA generation (if using OpenAI for instruction pairs)
OPENAI_API_KEY=sk-your-key-here

# Embedding model (default: multilingual for Arabic+English)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Chunk settings
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# LlamaParse tier
LLAMAPARSE_TIER=agentic
LLAMAPARSE_VERSION=latest
